# Neon PostgreSQL connection string, read by prisma.config.ts (and
# src/lib/prisma.ts via the PrismaPg driver adapter). Use your own Neon
# (or other Postgres) connection string — never commit real credentials.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth v5. Generate AUTH_SECRET with `npx auth secret` (or `openssl rand -base64 33`).
# GitHub OAuth app: https://github.com/settings/developers
# (callback URL: http://localhost:3000/api/auth/callback/github in dev)
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
